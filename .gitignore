# Yeni gorsel eklemek icin: lokal'de admin panelinden ekle, sonra git push.
# uploads/   <-- Render Free Tier kullanildigi icin commented out

# Calisma zamani veri dosyalari (production'da disk uzerinde tutulur)
data/sessions.json
data/analytics.json
data/contact-messages.log

# Editor / IDE
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Build / log
*.log
dist/
build/
