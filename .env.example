# =====================================================
#  AYDAKAR TEAM — Ortam Degiskenleri
#  Bu dosyayi ".env" olarak kopyalayip kendi degerlerinle doldur.
#  .env dosyasi GITLE PAYLASILMAMALI (sifre icerir).
# =====================================================

# ------- Mail (Iletisim formu) -------
# Mesajlarin gonderilecegi adres (varsayilan zaten aydakarteam@gmail.com)
CONTACT_TO=aydakarteam@gmail.com

# Gmail SMTP (varsayilan)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Gmail kullanici adi (genelde aydakarteam@gmail.com)
SMTP_USER=aydakarteam@gmail.com

# Gmail "Uygulama Sifresi" — normal Gmail sifren DEGIL!
# Nasil alinir:
# 1) https://myaccount.google.com/security adresine gir
# 2) "2 Adimli Dogrulama"yi etkinlestir (zorunlu)
# 3) https://myaccount.google.com/apppasswords adresine gir
# 4) "Mail" + "Other (Custom name)" sec, "AYDAKAR Web" yaz
# 5) Cikan 16 haneli sifreyi (bosluksuz) buraya yapistir
SMTP_PASS=xxxxxxxxxxxxxxxx

# ------- Admin -------
# Bos birakilirsa server.js icindeki varsayilan kullanilir
# ADMIN_PASSWORD=AydakarTeam..
# ADMIN_2FA=1905
